# ─────────────────────────────────────────────────────
# AuraBook — Variabili d'ambiente
# ─────────────────────────────────────────────────────
# Copia questo file come .env e compila con i valori reali.
# NON committare mai il file .env nel repository.
# ─────────────────────────────────────────────────────

# ── Firebase (frontend) ──
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ── EmailJS (frontend — notifica admin) ──
VITE_EMAILJS_SERVICE_ID=service_xxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ── Google Calendar (backend) ──
GOOGLE_CALENDAR_ID=email@gmail.com
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Alternativa per sviluppo locale (al posto di GOOGLE_SERVICE_ACCOUNT_CREDENTIALS):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=nome@progetto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Gmail SMTP (backend — email conferma al cliente) ──
GMAIL_USER=email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Cron job protezione (backend) ──
CRON_SECRET=your_random_secret_string
